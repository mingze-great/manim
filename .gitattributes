# Auto detect text files and perform LF normalization
* text=auto

# Python files - LF
*.py text eol=lf

# JavaScript/TypeScript - LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Config files - LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# Shell scripts - LF
*.sh text eol=lf

# Markdown - LF
*.md text eol=lf

# CSS - LF
*.css text eol=lf
*.scss text eol=lf

# HTML - LF
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mp3 binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.db binary
